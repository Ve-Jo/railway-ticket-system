{
  "name": "railway-ticket-system",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "node ./scripts/dev-runner.mjs",
    "dev:app": "concurrently \"npm run dev --workspace client\" \"npm run dev --workspace server\"",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server",
    "db:up": "docker compose up -d mysql",
    "db:down": "docker compose down",
    "db:init": "node ./scripts/init-db.mjs",
    "maintenance": "node ./scripts/run-maintenance.mjs",
    "regenerate:future-trips": "node ./scripts/regenerate-future-trips.mjs",
    "build": "npm run build --workspace client",
    "start": "npm run start --workspace server"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
